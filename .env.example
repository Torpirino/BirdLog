# Copia este archivo a .env y rellena los valores reales.
# .env NUNCA se sube a git (está en .gitignore).
# Ver docs/SEGURIDAD.md para detalles sobre el manejo de credenciales.

# Entorno: dev | prod
# - dev: usa la BD de desarrollo (fauna-dev)
# - prod: usa la BD de producción (fauna-prod) con datos reales
ENTORNO=dev

# ============================================================
# Supabase — entorno de desarrollo
# ============================================================
SUPABASE_DEV_URL=https://xxxxxxxx.supabase.co
SUPABASE_DEV_KEY=

# ============================================================
# Supabase — entorno de producción
# ============================================================
SUPABASE_PROD_URL=https://yyyyyyyy.supabase.co
SUPABASE_PROD_KEY=

# ============================================================
# Google Drive — credenciales y carpetas
# ============================================================
# Ruta absoluta al archivo JSON de credenciales de cuenta de servicio.
# Recomendación: guardarlo FUERA del repo, p.ej. en
#   ~/.config/sistema-fauna/google-credentials.json
GOOGLE_DRIVE_CREDENTIALS_PATH=

# ID de la carpeta raíz donde el observador sube las fotos
GOOGLE_DRIVE_CARPETA_FOTOS_ID=

# ID de la carpeta donde el script subirá los backups automáticos
GOOGLE_DRIVE_CARPETA_BACKUPS_ID=

# ============================================================
# Plaud
# ============================================================
# Ruta a la carpeta de Drive donde Plaud deja los .txt
PLAUD_CARPETA_TXT_ID=

# ============================================================
# Backups locales
# ============================================================
# Ruta absoluta a la carpeta donde guardar los backups en el ordenador.
# Si se deja vacía, se usa ./backups/ relativa al repo.
BACKUP_CARPETA_LOCAL=

# Días de retención de backups (más antiguos se borran automáticamente).
BACKUP_RETENCION_DIAS=30
